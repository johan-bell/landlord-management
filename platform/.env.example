# Use /api with Vite proxy to Nest on localhost:3000, or set full URL
VITE_API_URL=/api

# Landlord admin app origin (staff invitation links). Default: http://localhost:5173
# VITE_ADMIN_PUBLIC_URL=http://localhost:5173

# Platform UI feature flags (set to "false" to disable)
# VITE_FEATURE_PLATFORM_INTERNAL_NOTES=false
# VITE_FEATURE_PLATFORM_ONBOARDING=false
# VITE_FEATURE_PLATFORM_ANALYTICS=false
