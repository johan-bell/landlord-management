# PostgreSQL (required for Prisma). Use your real DB user and password — not the words USER/PASSWORD.
# Matches `docker compose` Postgres in this repo (user postgres, password postgres, db landlord):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/landlord?schema=public"

# HTTP (optional; default 3000)
PORT=3000

# JWT signing — set a long random string in production (dev fallback exists if unset)
JWT_SECRET=

# Access token lifetime for API + SPAs (e.g. 15m, 900, 8h). Default 8h.
# JWT_ACCESS_EXPIRES=8h

# Refresh token storage (days). Default 30.
# JWT_REFRESH_EXPIRES_DAYS=30

# Password reset & invite links (no trailing slash)
# ADMIN_PUBLIC_URL=http://localhost:5173
# PLATFORM_PUBLIC_URL=http://localhost:5175

# Rent reminder emails (cron daily 08:00 UTC). Requires EMAIL_ENABLED + SMTP.
# RENT_REMINDER_DAYS_BEFORE=3

# Optional error reporting
# SENTRY_DSN=

# CORS — JSON array of allowed browser origins. If unset, invalid, or empty array, cross-origin browser requests are blocked.
# Quote the whole value so .env parsers keep the JSON intact:
CORS_ORIGIN='["http://localhost:5173","http://localhost:5174","http://localhost:5175"]'

# Public tenant app URL (used in renter invite links from admin)
# TENANT_PUBLIC_URL=http://localhost:5174

# Stripe — optional; required for POST /billing/.../checkout
# STRIPE_SECRET_KEY=
# STRIPE_PRICE_ID=

# MinIO object storage (official `minio` npm client — env names stay S3_* for compatibility).
# Receipt uploads fail until these are set. Match docker-compose MinIO credentials and bucket.
# S3_ENDPOINT must use a host that resolves from this machine (127.0.0.1, localhost, or Docker service name `minio` from inside the api container — not an unmapped name like images.localhost unless it is in /etc/hosts).
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_ACCESS_KEY=landlordminio
# S3_SECRET_KEY=landlordminiochange
# S3_BUCKET=landlord-uploads
# S3_FORCE_PATH_STYLE=true

# Outbound email (optional). When EMAIL_ENABLED=true, configure SMTP — renters receive mail when a receipt is rejected.
# EMAIL_ENABLED=false
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM="Landlord App <no-reply@yourdomain.com>"
