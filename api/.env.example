# PostgreSQL (required for Prisma). Use your real DB user and password — not the words USER/PASSWORD.
# Matches `docker compose` Postgres in this repo (user postgres, password postgres, db landlord):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/landlord?schema=public"

# HTTP (optional; default 3000)
PORT=3000

# JWT signing — set a long random string in production (dev fallback exists if unset)
JWT_SECRET=

# CORS — JSON array of allowed browser origins. If unset, invalid, or empty array, cross-origin browser requests are blocked.
# Quote the whole value so .env parsers keep the JSON intact:
CORS_ORIGIN='["http://localhost:5173","http://localhost:5174","http://localhost:5175"]'

# Stripe — optional; required for POST /billing/.../checkout
# STRIPE_SECRET_KEY=
# STRIPE_PRICE_ID=
