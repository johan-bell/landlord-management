// Landlord Management — core domain (multi-tenant orgs)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrgRole {
  OWNER
  MANAGER
  STAFF
}

enum UnitStatus {
  VACANT
  OCCUPIED
}

/// Prepaid electricity is bought outside this app and not tracked here.
enum ElectricityBilling {
  PREPAID_EXTERNAL
  METERED_KWH
}

enum WaterBilling {
  NONE
  METERED_M3
}

enum PaymentStatus {
  PENDING
  PAID
  LATE
  CANCELLED
}

enum UtilityKind {
  ELECTRICITY
  WATER
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK
  OTHER
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum TenantSignupStatus {
  PENDING
  REJECTED
}

enum SupportRequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ProofVerificationStatus {
  NONE
  PENDING_VERIFICATION
  APPROVED
  REJECTED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  suspendedAt          DateTime?
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  /// Operator-only; never exposed to landlord staff or tenants via org APIs.
  platformInternalNotes String? @db.Text

  members              OrganizationMember[]
  invitations          OrganizationInvitation[]
  properties           Property[]
  renters              Renter[]
  tenantSignupRequests TenantSignupRequest[]
  supportRequests      SupportRequest[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  phone        String?
  isPlatformAdmin Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships              OrganizationMember[]
  renterProfile            Renter?
  organizationInvitationsCreated OrganizationInvitation[] @relation("InvitationCreatedBy")
  tenantSignupRequest      TenantSignupRequest?
  supportRequestsSubmitted SupportRequest[] @relation("SupportSubmitter")
  supportRequestsHandled   SupportRequest[] @relation("SupportHandler")
  paymentProofsVerified    Payment[]        @relation("PaymentProofVerifier")
  utilityBillProofsVerified LeaseUtilityBill[] @relation("UtilityBillProofVerifier")
  passwordResetTokens      PasswordResetToken[]
  refreshTokens            RefreshToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// typ: staff | platform | tenant (JWT audience for refresh)
model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  typ       String
  renterId  String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  actorUserId    String?
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([createdAt])
}

model OrganizationMember {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           OrgRole  @default(STAFF)
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model OrganizationInvitation {
  id              String   @id @default(cuid())
  organizationId  String
  email           String
  role            OrgRole  @default(STAFF)
  token           String   @unique
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  createdByUserId String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("InvitationCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
}

model Property {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  address        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  units        Unit[]

  @@index([organizationId])
}

model Unit {
  id         String     @id @default(cuid())
  propertyId String
  label      String
  rentAmount Decimal    @db.Decimal(12, 2)
  currency   String     @default("XAF")
  status     UnitStatus @default(VACANT)

  /// When METERED_KWH, bill using electricityPricePerKwh (per kWh). PREPAID_EXTERNAL = not tracked in app.
  electricityBilling     ElectricityBilling @default(PREPAID_EXTERNAL)
  electricityPricePerKwh Decimal?           @db.Decimal(14, 6)

  waterBilling    WaterBilling @default(NONE)
  waterPricePerM3 Decimal?     @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases   Lease[]

  @@index([propertyId])
}

model SupportRequest {
  id             String               @id @default(cuid())
  subject        String
  message        String               @db.Text
  status         SupportRequestStatus @default(OPEN)
  fromTenant     Boolean              @default(false)
  submitterId    String
  organizationId String?
  handledById    String?
  resolutionNote String?              @db.Text
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  closedAt       DateTime?

  submitter    User          @relation("SupportSubmitter", fields: [submitterId], references: [id], onDelete: Cascade)
  handledBy    User?         @relation("SupportHandler", fields: [handledById], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([organizationId])
  @@index([submitterId])
  @@index([createdAt])
}

model TenantSignupRequest {
  id             String             @id @default(cuid())
  organizationId String
  userId         String             @unique
  status         TenantSignupStatus @default(PENDING)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
}

/// Person renting a unit (domain term: tenant)
model Renter {
  id             String   @id @default(cuid())
  organizationId String
  fullName       String
  phone          String?
  email          String?
  idDocument     String?
  notes          String?
  userId         String?  @unique
  inviteToken          String?   @unique
  inviteTokenExpiresAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  leases       Lease[]

  @@index([organizationId])
}

model Lease {
  id         String    @id @default(cuid())
  unitId     String
  renterId   String
  startDate  DateTime
  endDate    DateTime?
  rentAmount Decimal   @db.Decimal(12, 2)
  currency   String    @default("XAF")
  dueDay     Int       @default(1)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  unit          Unit                 @relation(fields: [unitId], references: [id], onDelete: Cascade)
  renter        Renter               @relation(fields: [renterId], references: [id], onDelete: Cascade)
  payments      Payment[]
  utilityBills  LeaseUtilityBill[]

  @@index([unitId])
  @@index([renterId])
}

/// Monthly electricity or water charge for a lease (metered utilities only).
model LeaseUtilityBill {
  id        String        @id @default(cuid())
  leaseId   String
  kind      UtilityKind
  year      Int
  month     Int
  amount    Decimal       @db.Decimal(12, 2)
  currency  String        @default("XAF")
  dueDate   DateTime
  status    PaymentStatus @default(PENDING)
  paidAt    DateTime?

  /// Previous meter reading (m³ or kWh) for this billing period.
  previousIndex Decimal? @db.Decimal(18, 6)
  /// Current meter reading — consumption × unit price = amount when set.
  currentIndex  Decimal? @db.Decimal(18, 6)
  consumption   Decimal? @db.Decimal(18, 6)

  proofObjectKey          String?
  proofMimeType           String?
  proofVerification       ProofVerificationStatus @default(NONE)
  proofSubmittedAt        DateTime?
  proofVerifiedAt         DateTime?
  proofVerifiedByUserId   String?
  proofRejectionNote      String?                 @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lease         Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  proofVerifier User? @relation("UtilityBillProofVerifier", fields: [proofVerifiedByUserId], references: [id], onDelete: SetNull)

  @@unique([leaseId, kind, year, month])
  @@index([leaseId])
}

model Payment {
  id        String          @id @default(cuid())
  leaseId   String
  amount    Decimal         @db.Decimal(12, 2)
  currency  String          @default("XAF")
  dueDate   DateTime
  paidAt    DateTime?
  status    PaymentStatus   @default(PENDING)
  method    PaymentMethod   @default(OTHER)
  reference String?
  notes     String?

  proofObjectKey        String?
  proofMimeType         String?
  proofVerification     ProofVerificationStatus @default(NONE)
  proofSubmittedAt      DateTime?
  proofVerifiedAt       DateTime?
  proofVerifiedByUserId String?
  proofRejectionNote    String?                 @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lease         Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  proofVerifier User? @relation("PaymentProofVerifier", fields: [proofVerifiedByUserId], references: [id], onDelete: SetNull)

  @@index([leaseId])
  @@index([dueDate])
}
