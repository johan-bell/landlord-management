// Landlord Management — core domain (multi-tenant orgs)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrgRole {
  OWNER
  MANAGER
  STAFF
}

enum UnitStatus {
  VACANT
  OCCUPIED
}

enum PaymentStatus {
  PENDING
  PAID
  LATE
  CANCELLED
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK
  OTHER
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  suspendedAt          DateTime?
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  stripeCustomerId     String?
  stripeSubscriptionId String?

  members      OrganizationMember[]
  invitations  OrganizationInvitation[]
  properties   Property[]
  renters      Renter[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  phone        String?
  isPlatformAdmin Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships              OrganizationMember[]
  renterProfile            Renter?
  organizationInvitationsCreated OrganizationInvitation[] @relation("InvitationCreatedBy")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           OrgRole  @default(STAFF)
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model OrganizationInvitation {
  id              String   @id @default(cuid())
  organizationId  String
  email           String
  role            OrgRole  @default(STAFF)
  token           String   @unique
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  createdByUserId String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("InvitationCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
}

model Property {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  address        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  units        Unit[]

  @@index([organizationId])
}

model Unit {
  id         String     @id @default(cuid())
  propertyId String
  label      String
  rentAmount Decimal    @db.Decimal(12, 2)
  currency   String     @default("XAF")
  status     UnitStatus @default(VACANT)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases   Lease[]

  @@index([propertyId])
}

/// Person renting a unit (domain term: tenant)
model Renter {
  id             String   @id @default(cuid())
  organizationId String
  fullName       String
  phone          String?
  email          String?
  idDocument     String?
  notes          String?
  userId         String?  @unique
  inviteToken          String?   @unique
  inviteTokenExpiresAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  leases       Lease[]

  @@index([organizationId])
}

model Lease {
  id         String    @id @default(cuid())
  unitId     String
  renterId   String
  startDate  DateTime
  endDate    DateTime?
  rentAmount Decimal   @db.Decimal(12, 2)
  currency   String    @default("XAF")
  dueDay     Int       @default(1)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  unit     Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  renter   Renter    @relation(fields: [renterId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([unitId])
  @@index([renterId])
}

model Payment {
  id        String          @id @default(cuid())
  leaseId   String
  amount    Decimal         @db.Decimal(12, 2)
  currency  String          @default("XAF")
  dueDate   DateTime
  paidAt    DateTime?
  status    PaymentStatus   @default(PENDING)
  method    PaymentMethod   @default(OTHER)
  reference String?
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([leaseId])
  @@index([dueDate])
}
